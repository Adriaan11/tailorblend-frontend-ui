@* Custom Icon Component - Replaces MudIcon *@
@if (!string.IsNullOrEmpty(Icon))
{
    <svg class="tb-icon @SizeClass @Class" fill="@Fill" viewBox="0 0 24 24" stroke="currentColor" stroke-width="@StrokeWidth" style="@Style">
        @((MarkupString)GetIconPath())
    </svg>
}

@code {
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Size { get; set; } = "Medium";
    [Parameter] public string Color { get; set; } = "";
    [Parameter] public string Style { get; set; } = "";
    [Parameter] public string Class { get; set; } = "";

    private string Fill => Icon.Contains("Filled") ? "currentColor" : "none";
    private string StrokeWidth => Icon.Contains("Filled") ? "0" : "2";

    private string SizeClass => Size.ToLower() switch
    {
        "small" => "tb-icon--sm",
        "medium" => "tb-icon--md",
        "large" => "tb-icon--lg",
        _ => "tb-icon--md"
    };

    private string GetIconPath()
